# 真实 LLM 接入：复制本文件为 real-llm.env（git 已忽略），
# 填好你的 key，./.dev/bb-dev.sh up 会自动 source 进环境变量。
#
# 任选一段下面的 endpoint，注释掉其它段即可。
# 关键约束：模型必须支持 OpenAI 兼容的 function calling 协议
# （tools 字段 + tool_calls 流式 delta）。本表只列已知支持的。

# ============== OpenAI 官方 ==============
# export CHATGPT_API_KEY="sk-..."
# export CHATGPT_URL="https://api.openai.com/v1/chat/completions"
# export CHATGPT_MODEL="gpt-4o-mini"     # 也可 gpt-4o / gpt-4-turbo

# ============== DeepSeek（国内可直连，便宜） ==============
# export CHATGPT_API_KEY="sk-..."
# export CHATGPT_URL="https://api.deepseek.com/v1/chat/completions"
# export CHATGPT_MODEL="deepseek-chat"

# ============== Moonshot / Kimi ==============
# export CHATGPT_API_KEY="sk-..."
# export CHATGPT_URL="https://api.moonshot.cn/v1/chat/completions"
# export CHATGPT_MODEL="moonshot-v1-8k"

# ============== 阿里通义千问（Qwen）OpenAI 兼容端点 ==============
# export CHATGPT_API_KEY="sk-..."
# export CHATGPT_URL="https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions"
# export CHATGPT_MODEL="qwen-plus"      # 或 qwen-max / qwen-turbo

# ============== Claude (Anthropic) 通过 OpenAI 兼容代理 ==============
# 不直接支持。Anthropic 原生不是 OpenAI 协议，需要走 LiteLLM / OneAPI 等代理转译。
# 这里不示范。

# 你也可以另起 webSearch 后端：
# export AIAGENT_WEBSEARCH_SERPAPIKEY="..."     # 配了就走 SerpAPI，不配就走 DuckDuckGo HTML
